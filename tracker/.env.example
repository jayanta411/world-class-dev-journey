# ─── GitHub OAuth (for sign-in UI) ────────────────────────────────────────────
# Create a GitHub OAuth App at:
#   github.com → Settings → Developer settings → OAuth Apps → New OAuth App
#
# Application name:        World-Class Dev Tracker
# Homepage URL:            https://your-app.vercel.app
# Authorization callback:  https://your-app.vercel.app/api/auth/callback/github
#
# For local dev use:       http://localhost:3000/api/auth/callback/github
#
GITHUB_CLIENT_ID=Ov23liXXXXXXXXXXXXXX
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NextAuth secret — used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your-random-secret-here

# NextAuth base URL (set to your Vercel domain in production).
# On Vercel this is auto-detected; only set it locally if needed.
# NEXTAUTH_URL=http://localhost:3000

# ─── GitHub integration (for read/write to subjects.json) ─────────────────────
# Create a GitHub Personal Access Token (fine-grained) with:
#   - Repository: world-class-dev-journey
#   - Contents: Read & Write
#
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The GitHub account / org that owns the repo
GITHUB_OWNER=jayanta411

# The repository name
GITHUB_REPO=world-class-dev-journey

# ─── Allow-list (optional) ────────────────────────────────────────────────────
# Comma-separated GitHub usernames that are allowed to sign in and edit.
# Defaults to "jayanta411" if not set.
# ALLOWED_GITHUB_LOGINS=jayanta411
